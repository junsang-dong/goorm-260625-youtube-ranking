# PlayRank Environment Variables

# Server-side only — never expose to frontend
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# --- LLM providers ---
# OpenAI (GPT) — required (insights + multi-LLM analysis)
OPENAI_API_KEY=your_openai_api_key
# Optional: defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Anthropic (Claude) — required for multi-LLM analysis (trust + synthesis)
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional: defaults to claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
# Google Gemini — optional (classification; falls back to Claude)
GEMINI_API_KEY=your_gemini_api_key
# Optional: defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
# Perplexity — optional (trend tracking; falls back to GPT)
PERPLEXITY_API_KEY=your_perplexity_api_key
# Optional: defaults to sonar
PERPLEXITY_MODEL=sonar

DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Client-exposed
VITE_APP_TITLE=PlayRank
